# --- Python ---
# --- Credenciales Cloud (NUNCA subir al repo) ---
cloud_credentials/
*.json.key

__pycache__/
*.py[cod]
*$py.class
.venv
venv/
ENV/
.env

# --- Jupyter Notebooks ---
.ipynb_checkpoints
*/.ipynb_checkpoints/*
*-checkpoint.ipynb

# --- Databases & Data Files ---
*.db
*.db-journal
*.sqlite
*.duckdb
*.wal
*.csv
*.xlsx
*.parquet

# --- Data & Landing (Ignore local large files) ---
# Allow keeping the directories but ignore the content
data/landing/*
data/playground/*
data/bronze/*
data/silver/*
data/gold/*
!**/README.md
!**/.gitkeep

# --- IDEs ---
.vscode/
.idea/
.project
.pydevproject

# --- OS ---
.DS_Store
Thumbs.db

# --- Uso Interno del Profe (no subir a GitHub) ---
MANTENIMIENTO.md

# --- Logs & Performance ---
*.log
.airflow/
logs/
plugins/

# --- Office / Binarios pesados ---
*.pptx
*.pdf

# --- Data runtime outputs (regenerados por DAGs, no committear) ---
stack/data/processed/**
stack/data/quarantine/**
!stack/data/processed/.gitkeep
!stack/data/quarantine/.gitkeep

# --- Credenciales Cloud (defensa adicional - .json/.key reales nunca subir) ---
stack/credentials/*.json
stack/credentials/*.key

# --- Excepcion: el .env del stack del laboratorio si se versiona ---
# Son credenciales locales-only (admin/admin) sin info sensible real.
!stack/.env
