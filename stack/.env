# ==================================================
# CONFIGURACION DE METADATOS (AIRFLOW)
# ==================================================
AF_DB_USER=airflow
AF_DB_PASS=airflow
AF_DB_NAME=airflow

AIRFLOW__WEBSERVER__SECRET_KEY=94943fcf3eef3f6f94f943fcf3eef3f6

# ==================================================
# CONFIGURACION DE DATOS SOURCE (POSTGRES)
# ==================================================
SOURCE_DB_USER=admin
SOURCE_DB_PASS=admin
SOURCE_DB_NAME=InfraCienciaDatos

# ==================================================
# PERFORMANCE & AJUSTES
# ==================================================
# Estabilizacion para entornos locales (Windows/WSL)
AIRFLOW__CORE__PARALLELISM=4
AIRFLOW__CORE__MAX_ACTIVE_TASKS_PER_DAG=4
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW_UID=0
AIRFLOW__CORE__EXECUTOR=LocalExecutor

# ==================================================
# AUTENTICACION (SIMPLE AUTH MANAGER - AIRFLOW 3.x)
# ==================================================
# Todos son admin, sin login
AIRFLOW__CORE__SIMPLE_AUTH_MANAGER_ALL_ADMINS=True

# ==================================================
# GOOGLE CLOUD PLATFORM (OPCIONAL - Solo para clases de Cloud)
# Dejar estos valores por defecto si no tenes credenciales GCP.
# El stack funciona perfectamente sin ellos.
# ==================================================
GCP_PROJECT_ID=tu-proyecto-id
GCP_GCS_BUCKET=nombre-de-tu-bucket
GCP_LOCATION=US
